# Backend server
SERVER_PORT=8090

# Datasource (Neon/PostgreSQL example)
# IMPORTANT: replace values with your own credentials.
SPRING_DATASOURCE_URL=jdbc:postgresql://ep-your-neon-host.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
SPRING_DATASOURCE_DRIVER_CLASS_NAME=org.postgresql.Driver
SPRING_DATASOURCE_USERNAME=neondb_owner
SPRING_DATASOURCE_PASSWORD=replace_me

# Optional: disable H2 console when using cloud DB
SPRING_H2_CONSOLE_ENABLED=false

# Android gateway bridge defaults
GATEWAY_BASE_URL=http://192.168.1.37:8082
GATEWAY_TOKEN=replace_me
GATEWAY_DEFAULT_LIMIT=100
